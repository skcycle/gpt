<Window x:Class="MotionControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="Motion Control Console"
        Height="1080"
        Width="1920"
        MinHeight="680"
        MinWidth="980">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="MOTION CONTROL CONSOLE" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="ZMC real-time diagnostics, axis operation and EtherCAT monitoring" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding OperationStatus}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Background="#0E2E2A" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="18" Padding="14,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentBeijingTime}" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="White" FontWeight="SemiBold" />
                        <Ellipse Width="10" Height="10" Fill="{Binding Dashboard.ConnectionStatusColor, FallbackValue=#EF4444}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Dashboard.ConnectionStatusText, FallbackValue=Offline}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="E-STOP" Command="{Binding EmergencyStopCommand}" Margin="20,0,0,0" Padding="10,4" FontWeight="Bold" Background="#8B0000" Foreground="White" />
                        <Button Content="CLR ESTOP" Command="{Binding ClearEmergencyStopCommand}" Margin="6,0,0,0" Padding="10,4" FontWeight="Bold" Background="#1A5C1A" Foreground="White" />
                        <Button Content="Reconnect" Command="{Binding ReconnectCommand}" Margin="6,0,0,0" Padding="10,4" FontWeight="Bold" Background="#1A4A8B" Foreground="White" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,14">
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="System State" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.SystemState}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="EtherCAT Status" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatNetworkState}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Connected" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatConnected}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Online Slaves" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatOnlineSlaveCount}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Alarm Count" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.AlarmCount}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Active IO" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.ActiveInputCount}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                                <TextBlock Text="DI ON" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding Dashboard.ActiveOutputCount}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="DO ON" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <GroupBox Grid.Row="1" Header="Alarm Log" MinWidth="520">
                        <ListBox ItemsSource="{Binding Dashboard.AlarmLog}" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="EtherCAT Monitor">
                <Grid Margin="12">
                    <DataGrid ItemsSource="{Binding EtherCatMonitor.Slaves}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SlaveNo" Binding="{Binding SlaveNo}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                            <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="120" />
                            <DataGridTextColumn Header="ModuleState" Binding="{Binding ModuleState}" Width="120" />
                            <DataGridTextColumn Header="Topology" Binding="{Binding TopologyPath}" Width="120" />
                            <DataGridTextColumn Header="VendorId" Binding="{Binding VendorId}" Width="120" />
                            <DataGridTextColumn Header="ProductCode" Binding="{Binding ProductCode}" Width="140" />
                            <DataGridTextColumn Header="FaultText" Binding="{Binding FaultText}" Width="220" />
                            <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline, Mode=OneWay}" Width="100" />
                            <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm, Mode=OneWay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Axis Console">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="400" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.5*" MinWidth="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Axis Monitor (full height) -->
                    <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Axis Monitor" FontSize="22" FontWeight="Bold" />
                                    <TextBlock Text="Real-time axis overview and selection" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="Add Axis" Command="{Binding AddAxisCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="100" />
                                    <Button Content="Delete Axis" Command="{Binding DeleteAxisCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="100" />
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      x:Name="AxisMonitorDataGrid"
                                      ItemsSource="{Binding AxisMonitor.Axes}"
                                      SelectedItem="{Binding AxisMonitor.SelectedAxis, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HorizontalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="AxisMonitorDataGrid_PreviewMouseWheel">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#E6EEF8" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#27C1A5" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#27C1A5" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="AxisNo" Binding="{Binding AxisNo}" Width="60" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="90" />
                                    <DataGridTextColumn Header="Cmd(mm)" Binding="{Binding CommandPositionMm, StringFormat=F3}" Width="90" />
                                    <DataGridTextColumn Header="Enc(mm)" Binding="{Binding EncoderPositionMm, StringFormat=F3}" Width="90" />
                                    <DataGridTextColumn Header="Velocity" Binding="{Binding CurrentVelocity}" Width="80" />
                                    <DataGridTextColumn Header="WorkVel" Binding="{Binding WorkVelocity}" Width="70" />
                                    <DataGridTextColumn Header="SetupVel" Binding="{Binding SetupVelocity}" Width="70" />
                                    <DataGridCheckBoxColumn Header="Homed" Binding="{Binding IsHomed, Mode=OneWay}" Width="55">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridTemplateColumn Header="ServoOn" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsServoOn, Mode=OneWay}"
                                                          Command="{Binding ToggleServoCommand}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Alarm" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding HasAlarm, Mode=OneWay}"
                                                          Command="{Binding ClearAlarmCommand}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="Soft-" Binding="{Binding NegativeSoftLimitTriggered, Mode=OneWay}" Width="55">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Header="Soft+" Binding="{Binding PositiveSoftLimitTriggered, Mode=OneWay}" Width="55">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Header="Hard-" Binding="{Binding NegativeHardLimitTriggered, Mode=OneWay}" Width="55">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Header="Hard+" Binding="{Binding PositiveHardLimitTriggered, Mode=OneWay}" Width="55">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                    </DataGridCheckBoxColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Column 2: Axis Manual Operation -->
                    <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Axis Manual Operation" FontSize="20" FontWeight="Bold" Margin="0,0,0,14" />

                            <TextBlock Text="Selected Axis" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBlock Text="{Binding AxisDebug.SelectedAxisNo}" FontSize="20" FontWeight="Bold" Margin="0,6,0,10" />

                            <TextBlock Text="Target Position" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.TargetPosition}" Margin="0,6,0,10" />

                            <TextBlock Text="Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Velocity}" Margin="0,6,0,10" />

                            <TextBlock Text="Acceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Acceleration}" Margin="0,6,0,10" />

                            <TextBlock Text="Deceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Deceleration}" Margin="0,6,0,14" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Home" Command="{Binding AxisDebug.HomeAxisCommand}" Width="80" Margin="0,0,6,0" />
                                <Button Content="Move" Command="{Binding AxisDebug.MoveAxisCommand}" Width="80" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding AxisDebug.StopAxisCommand}" Width="80" Margin="0,0,6,0" />
                                <Button x:Name="JogPositiveButton" Content="Jog +" PreviewMouseLeftButtonDown="JogPositiveButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" Width="80" Margin="0,0,6,0" />
                                <Button x:Name="JogNegativeButton" Content="Jog -" PreviewMouseLeftButtonDown="JogNegativeButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" Width="80" Margin="0,0,6,0" />
                            </StackPanel>

                            <GroupBox Header="Recent Runtime Events" Margin="0,16,0,0">
                                <DataGrid ItemsSource="{Binding Dashboard.RecentCommandFeedback}" AutoGenerateColumns="False" IsReadOnly="True" Height="220" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                        <DataGridTextColumn Header="Axis" Binding="{Binding Axis}" Width="80" />
                                        <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="160" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </Border>

                    <!-- Right column: Axis Parameters -->
                    <Border Grid.Column="4" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="14">
                        <ScrollViewer x:Name="AxisParametersScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="AxisParametersScrollViewer_PreviewMouseWheel">
                            <StackPanel>
                                <TextBlock Text="Axis Parameters" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />

                                <TextBlock Text="Axis No" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.AxisNo}" Margin="0,6,0,8" IsReadOnly="True" />

                                <TextBlock Text="Name" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.Name}" Margin="0,6,0,8" />

                                <TextBlock Text="SoftLimit Negative" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.SoftLimitNegative}" Margin="0,6,0,8" />

                                <TextBlock Text="SoftLimit Positive" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.SoftLimitPositive}" Margin="0,6,0,8" />

                                <TextBlock Text="Work Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.WorkVelocity}" Margin="0,6,0,8" />

                                <TextBlock Text="Setup Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.SetupVelocity}" Margin="0,6,0,8" />

                                <TextBlock Text="Acceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.Acceleration}" Margin="0,6,0,8" />

                                <TextBlock Text="Deceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.Deceleration}" Margin="0,6,0,8" />

                                <TextBlock Text="Pulse Equivalent (pulse/mm)" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.PulseEquivalent}" Margin="0,6,0,8" />

                                <TextBlock Text="HomeMode" Foreground="{StaticResource SecondaryTextBrush}" />
                                <ComboBox ItemsSource="{Binding AxisParameterEditor.HomeModes}" SelectedItem="{Binding AxisParameterEditor.HomeMode}" Margin="0,6,0,8" />

                                <TextBlock Text="Servo Binding" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBox Text="{Binding AxisParameterEditor.ServoBinding}" Margin="0,6,0,12" />

                                <WrapPanel>
                                    <Button Content="Load Config" Command="{Binding AxisParameterEditor.LoadCommand}" Width="120" Margin="0,0,8,0" />
                                    <Button Content="Save Config" Command="{Binding AxisParameterEditor.SaveCommand}" Width="120" Margin="0,0,8,0" />
                                    <Button Content="Read Ctrl" Command="{Binding AxisParameterEditor.ReadControllerCommand}" Width="120" Margin="0,0,8,0" />
                                    <Button Content="Write Ctrl" Command="{Binding AxisParameterEditor.WriteControllerCommand}" Width="120" Margin="0,0,8,0" />
                                </WrapPanel>

                                <TextBlock Text="{Binding AxisParameterEditor.ControllerParameterSnapshot}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="IO Monitor">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="Add DI" Command="{Binding AddInputCommand}" Padding="10,4" Margin="0,0,8,0" Background="#1A4A8B" Foreground="White" />
                        <Button Content="Delete DI" Command="{Binding DeleteInputCommand}" Padding="10,4" Margin="0,0,16,0" Background="#8B0000" Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#8B0000" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#5A1E1E" />
                                            <Setter Property="Foreground" Value="#E6EEF8" />
                                            <Setter Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Add DO" Command="{Binding AddOutputCommand}" Padding="10,4" Margin="0,0,8,0" Background="#1A4A8B" Foreground="White" />
                        <Button Content="Delete DO" Command="{Binding DeleteOutputCommand}" Padding="10,4" Margin="0,0,16,0" Background="#8B0000" Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#8B0000" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#5A1E1E" />
                                            <Setter Property="Foreground" Value="#E6EEF8" />
                                            <Setter Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Save" Command="{Binding SaveIoConfigCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="100" Background="#1A5C1A" Foreground="White" />
                        <Button Content="Load" Command="{Binding LoadIoConfigCommand}" Padding="10,4" MinWidth="100" Margin="0,0,8,0" Background="#1A5C1A" Foreground="White" />
                        <TextBlock Text="{Binding OperationStatus}" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#E6EEF8" TextWrapping="Wrap" MaxWidth="400" />
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="Digital Inputs">
                        <DataGrid ItemsSource="{Binding IoMonitor.Inputs}" SelectedItem="{Binding IoMonitor.SelectedInput, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                <DataGridTextColumn Header="Address" Binding="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTemplateColumn Header="Value" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="14" Height="14" Fill="{Binding StatusBrush}" Stroke="#404040" StrokeThickness="1" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Toggle" Width="80" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="56" Background="Transparent" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Grid.Column="2" Header="Digital Outputs">
                        <DataGrid ItemsSource="{Binding IoMonitor.Outputs}" SelectedItem="{Binding IoMonitor.SelectedOutput, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                <DataGridTextColumn Header="Address" Binding="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTemplateColumn Header="Value" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="14" Height="14" Fill="{Binding StatusBrush}" Stroke="#404040" StrokeThickness="1" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Toggle" Width="80" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Toggle"
                                                    Command="{Binding SetCommand}"
                                                    Width="56"
                                                    Padding="4,2" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.ColumnSpan="3" Grid.Row="4" Header="IO Event Log">
                        <DataGrid ItemsSource="{Binding IoEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                <DataGridTextColumn Header="Point" Binding="{Binding Direction}" Width="120" />
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="120" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Description}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Cylinder Monitor">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Add Cylinder" Command="{Binding AddCylinderCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="120" />
                        <Button Content="Delete Cylinder" Command="{Binding DeleteCylinderCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="120" />
                        <Button Content="Save Config" Command="{Binding SaveCylinderConfigCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="120" />
                        <Button Content="Load Config" Command="{Binding LoadCylinderConfigCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="120" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CylinderMonitor.Cylinders}"
                              SelectedItem="{Binding CylinderMonitor.SelectedCylinder, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              VerticalContentAlignment="Center"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                            <DataGridTemplateColumn Header="Extend DI" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Width="12" Height="12" Fill="{Binding ExtendDiBrush}" Stroke="#404040" StrokeThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ExtendSensorInputAddress}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ExtendSensorInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Retract DI" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Width="12" Height="12" Fill="{Binding RetractDiBrush}" Stroke="#404040" StrokeThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding RetractSensorInputAddress}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding RetractSensorInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Extend DO" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Width="12" Height="12" Fill="{Binding ExtendDoBrush}" Stroke="#404040" StrokeThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ExtendOutputAddress}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ExtendOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Retract DO" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Width="12" Height="12" Fill="{Binding RetractDoBrush}" Stroke="#404040" StrokeThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding RetractOutputAddress}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding RetractOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Timeout(ms)" Binding="{Binding ActionTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="16" Height="16" Fill="{Binding StatusBrush}" Stroke="#404040" StrokeThickness="1" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="110" />
                            <DataGridTemplateColumn Header="Actions" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="Open" Command="{Binding OpenCommand}" Width="80" Margin="0,0,6,0" />
                                            <Button Content="Close" Command="{Binding CloseCommand}" Width="80" Margin="0,0,6,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="2" Header="Cylinder Event Log">
                        <DataGrid ItemsSource="{Binding CylinderEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                <DataGridTextColumn Header="Cylinder" Binding="{Binding CylinderName}" Width="180" />
                                <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="120" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Description}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Work Head Monitor">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Add Object" Command="{Binding AddWorkHeadCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="90" />
                        <Button Content="Delete Object" Command="{Binding DeleteWorkHeadCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="100" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <Button Content="Add Position" Command="{Binding AddWorkHeadPositionCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="95" />
                        <Button Content="Delete Position" Command="{Binding DeleteWorkHeadPositionCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="105" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <Button Content="Save" Command="{Binding SaveWorkHeadConfigCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="70" />
                        <Button Content="Load" Command="{Binding LoadWorkHeadConfigCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="70" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <TextBlock Text="{Binding OperationStatus}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxWidth="400" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" MinWidth="150" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="200" MinWidth="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Objects">
                            <DataGrid ItemsSource="{Binding WorkHeadMonitor.WorkHeads}"
                                      SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Positions">
                            <DataGrid ItemsSource="{Binding WorkHeadMonitor.SelectedWorkHead.Positions}"
                                      SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead.PositionSelector, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Name" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="4" Header="Setup">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <UniformGrid Grid.Row="0" Columns="4">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="X Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Y Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Z Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="R Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.RAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <UniformGrid Grid.Row="2" Columns="4">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="X Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsXAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Y Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsYAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Z Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsZAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="R Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsRAxisConfigured}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <Grid Grid.Row="4" Margin="4,0,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Safe Z" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="3" Text="Description" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="4" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <UniformGrid Grid.Row="6" Columns="8">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Vacuum DO" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Blow DO" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.BlowOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Vacuum DI" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="General DO 1" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="General DO 2" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="General DI 1" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="General DI 2" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Vacuum Timeout(ms)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="4,0,4,4">
                                        <Button Content="Teach" Command="{Binding WorkHeadMonitor.SelectedWorkHead.TeachPositionCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="80" />
                                        <Button Content="Move" Command="{Binding WorkHeadMonitor.SelectedWorkHead.MovePositionCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="80" />
                                        <Button Content="Vacuum" Command="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="90" />
                                        <Button Content="Blow" Command="{Binding WorkHeadMonitor.SelectedWorkHead.BlowCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="80" />
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Work Head Event Log">
                        <DataGrid ItemsSource="{Binding WorkHeadEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                <DataGridTextColumn Header="WorkHead" Binding="{Binding WorkHeadName}" Width="180" />
                                <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="120" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Position Setup">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Add Object" Command="{Binding AddPositionSetupCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="90" />
                        <Button Content="Delete Object" Command="{Binding DeletePositionSetupCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="100" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <Button Content="Add Position" Command="{Binding AddPositionSetupPositionCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="95" />
                        <Button Content="Delete Position" Command="{Binding DeletePositionSetupPositionCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="105" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <Button Content="Save" Command="{Binding SavePositionSetupConfigCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="70" />
                        <Button Content="Load" Command="{Binding LoadPositionSetupConfigCommand}" Padding="10,4" Margin="0,0,6,0" MinWidth="70" />
                        <Rectangle Width="1" Fill="#3A3A3A" Margin="8,4" />
                        <TextBlock Text="{Binding OperationStatus}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" MaxWidth="400" />
                    </StackPanel>

                    <!-- Main area: Objects | Positions | Setup -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" MinWidth="150" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="200" MinWidth="130" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Column 0: Objects list -->
                        <GroupBox Header="Objects">
                            <DataGrid ItemsSource="{Binding PositionSetupMonitor.Items}"
                                      SelectedItem="{Binding PositionSetupMonitor.SelectedItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <!-- Column 2: Positions under selected object -->
                        <GroupBox Grid.Column="2" Header="Positions">
                            <DataGrid ItemsSource="{Binding PositionSetupMonitor.SelectedItem.Positions}"
                                      SelectedItem="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <!-- Column 4: Setup (axis mapping + position values + SafeZ) -->
                        <GroupBox Grid.Column="4" Header="Setup">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Axis mapping (object-level, shared by all positions) -->
                                    <UniformGrid Grid.Row="0" Columns="7">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Xx Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XxAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="X Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Y Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Z Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="U Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.UAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="V Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.VAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="W Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.WAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- Position values (position-level) -->
                                    <UniformGrid Grid.Row="2" Columns="7">
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Xx Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XxPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXxAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="X Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Y Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.YPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsYAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="Z Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.ZPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsZAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="U Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.UPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsUAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="V Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.VPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsVAxisConfigured}" />
                                        </StackPanel>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="W Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                            <TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.WPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}"
                                                     IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsWAxisConfigured}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- SafeZ and Description (object-level) -->
                                    <Grid Grid.Row="4" Margin="4,0,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Safe Z" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="3" Text="Description" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="4" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="4,0,4,4">
                                        <Button Content="Teach" Command="{Binding TeachPositionSetupCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="80" />
                                        <Button Content="Move" Command="{Binding MovePositionSetupCommand}" Padding="10,4" Margin="0,0,8,0" MinWidth="80" />
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Position Setup Event Log">
                        <DataGrid ItemsSource="{Binding PositionSetupEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                <DataGridTextColumn Header="Position" Binding="{Binding PositionName}" Width="180" />
                                <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="120" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Alarm">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Alarm Center" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

                    <GroupBox Grid.Row="1" Header="Active Alarm Axes" Margin="0,8,0,12">
                        <ListBox ItemsSource="{Binding Alarm.ActiveAlarmAxes}" />
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Alarm.ActiveAlarms}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="220" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" />
                            <DataGridTextColumn Header="OccurredAt" Binding="{Binding OccurredAt}" Width="180" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
