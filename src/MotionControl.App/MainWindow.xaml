<Window x:Class="MotionControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="Motion Control Console"
        Height="760"
        Width="1280"
        MinHeight="680"
        MinWidth="1180">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="MOTION CONTROL CONSOLE" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="ZMC real-time diagnostics, axis operation and EtherCAT monitoring" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Column="1" Background="#0E2E2A" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="18" Padding="14,8" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrushStrong}" Margin="0,0,8,0" />
                        <TextBlock Text="Industrial Runtime Online" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="5" Margin="0,0,0,14">
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="System State" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.SystemState}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="EtherCAT Status" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatNetworkState}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Connected" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatConnected}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Online Slaves" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.EtherCatOnlineSlaveCount}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Alarm Count" Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding Dashboard.AlarmCount}" FontSize="22" FontWeight="Bold" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="200" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding Dashboard.EtherCatSlaves}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SlaveNo" Binding="{Binding SlaveNo}" Width="100" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                                <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="140" />
                                <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline, Mode=OneWay}" Width="100" />
                                <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm, Mode=OneWay}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GroupBox Grid.Row="1" Header="Recent Command Feedback">
                            <ListBox ItemsSource="{Binding Dashboard.RecentCommandFeedback}" />
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Axis Monitor">
                <Grid Margin="12">
                    <DataGrid ItemsSource="{Binding AxisMonitor.Axes}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="AxisNo" Binding="{Binding AxisNo}" Width="80" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" />
                            <DataGridTextColumn Header="Position" Binding="{Binding CurrentPosition}" Width="140" />
                            <DataGridTextColumn Header="Velocity" Binding="{Binding CurrentVelocity}" Width="140" />
                            <DataGridTextColumn Header="HomeMode" Binding="{Binding HomeMode}" Width="150" />
                            <DataGridTextColumn Header="ServoBinding" Binding="{Binding ServoBinding}" Width="150" />
                            <DataGridTextColumn Header="SoftLimit" Binding="{Binding SoftLimitDisplay}" Width="180" />
                            <DataGridCheckBoxColumn Header="Homed" Binding="{Binding IsHomed, Mode=OneWay}" Width="90" />
                            <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm, Mode=OneWay}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Axis Debug">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Axis Manual Operation" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />

                            <TextBlock Text="Axis Selection" Foreground="{StaticResource SecondaryTextBrush}" />
                            <ComboBox ItemsSource="{Binding AxisMonitor.Axes}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="AxisNo"
                                      SelectedValue="{Binding AxisDebug.SelectedAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,6,0,10" />

                            <TextBlock Text="Target Position" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.TargetPosition}" Margin="0,6,0,10" />

                            <TextBlock Text="Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Velocity}" Margin="0,6,0,10" />

                            <TextBlock Text="Acceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Acceleration}" Margin="0,6,0,10" />

                            <TextBlock Text="Deceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding AxisDebug.Deceleration}" Margin="0,6,0,14" />

                            <WrapPanel>
                                <Button Content="Enable" Command="{Binding AxisDebug.EnableAxisCommand}" Width="96" />
                                <Button Content="Home" Command="{Binding AxisDebug.HomeAxisCommand}" Width="96" />
                                <Button Content="Move" Command="{Binding AxisDebug.MoveAxisCommand}" Width="96" />
                                <Button Content="Stop" Command="{Binding AxisDebug.StopAxisCommand}" Width="96" />
                                <Button x:Name="JogPositiveButton" Content="Jog +" Command="{Binding AxisDebug.JogPositiveCommand}" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" Width="96" />
                                <Button x:Name="JogNegativeButton" Content="Jog -" Command="{Binding AxisDebug.JogNegativeCommand}" PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" MouseLeave="JogButton_MouseLeave" Width="96" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="12" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Selected Axis Diagnostics" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

                            <UniformGrid Columns="2" Margin="0,0,0,16">
                                <Border Background="{StaticResource PanelBackgroundAltBrush}" CornerRadius="10" Padding="12" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="HomeMode" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding AxisDebug.SelectedAxisHomeMode}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource PanelBackgroundAltBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="ServoBinding" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding AxisDebug.SelectedAxisServoBinding}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource PanelBackgroundAltBrush}" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="SoftLimit" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="{Binding AxisDebug.SelectedAxisSoftLimit}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource PanelBackgroundAltBrush}" CornerRadius="10" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Jog Mode" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <TextBlock Text="Press and hold to run, release to stop" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <GroupBox Header="Home Plan">
                                <StackPanel>
                                    <TextBlock Text="{Binding AxisDebug.SelectedHomePlanTitle}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding AxisDebug.SelectedHomePlanSteps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="EtherCAT Monitor">
                <Grid Margin="12">
                    <DataGrid ItemsSource="{Binding EtherCatMonitor.Dashboard.EtherCatSlaves}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SlaveNo" Binding="{Binding SlaveNo}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                            <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="140" />
                            <DataGridTextColumn Header="FaultText" Binding="{Binding FaultText}" Width="220" />
                            <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline, Mode=OneWay}" Width="100" />
                            <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm, Mode=OneWay}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Alarm">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Alarm Center" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

                    <GroupBox Grid.Row="1" Header="Active Alarm Axes" Margin="0,8,0,12">
                        <ListBox ItemsSource="{Binding Alarm.ActiveAlarmAxes}" />
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Alarm.ActiveAlarms}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="220" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" />
                            <DataGridTextColumn Header="OccurredAt" Binding="{Binding OccurredAt}" Width="180" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
