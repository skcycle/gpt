<Window x:Class="MotionControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MotionControl.Presentation.ViewModels;assembly=MotionControl.Presentation"
        WindowStartupLocation="CenterScreen"
        Title="Motion Control Console"
        Height="1080"
        Width="1920"
        MinHeight="680"
        MinWidth="1180">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#121C25" BorderBrush="#223240" BorderThickness="0,0,1,0" Padding="20,22,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="48" Height="48" CornerRadius="12" Background="#223240" HorizontalAlignment="Left">
                        <Viewbox Margin="10">
                            <Path Fill="{StaticResource AccentBrush}"
                                  Data="M10,2 L18,2 C20.2,2 22,3.8 22,6 L22,18 C22,20.2 20.2,22 18,22 L6,22 C3.8,22 2,20.2 2,18 L2,10 Z M6,4 C4.9,4 4,4.9 4,6 L4,18 C4,19.1 4.9,20 6,20 L18,20 C19.1,20 20,19.1 20,18 L20,8 L16,8 C12.7,8 10,5.3 10,2 Z" />
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Motion Control" FontSize="24" FontWeight="Bold" Margin="0,16,0,0" />
                    <TextBlock Text="Premium industrial control console" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <ToggleButton x:Name="NavDashboardButton" Style="{StaticResource NavItemButtonStyle}" Click="NavDashboard_Click" IsChecked="True">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M3,11 L11,3 L21,13 L21,22 L14,22 L14,16 L10,16 L10,22 L3,22 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Dashboard" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavEtherCatButton" Style="{StaticResource NavItemButtonStyle}" Click="NavEtherCat_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M4,7 L11,7 L11,4 L20,4 L20,11 L17,11 L17,14 L20,14 L20,20 L11,20 L11,17 L4,17 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="EtherCAT" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavAxisButton" Style="{StaticResource NavItemButtonStyle}" Click="NavAxis_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M3,18 L3,6 L6,6 L6,18 Z M10,21 L10,3 L13,3 L13,21 Z M17,15 L17,8 L20,8 L20,15 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Axis Console" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavIoButton" Style="{StaticResource NavItemButtonStyle}" Click="NavIo_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M4,4 L10,4 L10,8 L14,8 L14,4 L20,4 L20,10 L16,10 L16,14 L20,14 L20,20 L14,20 L14,16 L10,16 L10,20 L4,20 L4,14 L8,14 L8,10 L4,10 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="IO Monitor" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavCylinderButton" Style="{StaticResource NavItemButtonStyle}" Click="NavCylinder_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M3,9 L15,9 L15,6 L21,6 L21,18 L15,18 L15,15 L3,15 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Cylinder" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavMagazineButton" Style="{StaticResource NavItemButtonStyle}" Click="NavMagazine_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M4,5 L20,5 L20,9 L4,9 Z M4,11 L20,11 L20,15 L4,15 Z M4,17 L20,17 L20,21 L4,21 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Magazine" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavWorkHeadButton" Style="{StaticResource NavItemButtonStyle}" Click="NavWorkHead_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M12,3 A5,5 0 1 1 11.9,3 Z M9,12 L15,12 L18,21 L15,21 L13.8,17.5 L10.2,17.5 L9,21 L6,21 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Work Head" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavPositionSetupButton" Style="{StaticResource NavItemButtonStyle}" Click="NavPositionSetup_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="{StaticResource AccentBrushStrong}" Data="M11,3 L13,3 L13,9 L19,9 L19,11 L13,11 L13,17 L11,17 L11,11 L5,11 L5,9 L11,9 Z M12,19 A3,3 0 1 1 11.9,19 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Position Setup" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                    <ToggleButton x:Name="NavAlarmButton" Style="{StaticResource NavItemButtonStyle}" Click="NavAlarm_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Path Fill="#D8AE67" Data="M12,3 L22,21 L2,21 Z M11,9 L13,9 L13,15 L11,15 Z M11,17 L13,17 L13,19 L11,19 Z" />
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Alarm" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </ToggleButton>
                </StackPanel>

                <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Controller" Foreground="{StaticResource SecondaryTextBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse Width="10" Height="10" Fill="{Binding Dashboard.ConnectionStatusColor, FallbackValue=#B85E5E}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding Dashboard.ConnectionStatusText, FallbackValue=Offline}" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentBeijingTime}" Margin="0,10,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="16" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding CurrentPageTitle}" FontSize="28" FontWeight="Bold" />
                        <TextBlock Text="{Binding CurrentPageDescription}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                        <TextBlock Text="{Binding OperationStatus}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="760" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusChipBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Time" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding CurrentBeijingTime}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusChipBorderStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="{Binding Dashboard.ConnectionStatusColor, FallbackValue=#B85E5E}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Dashboard.ConnectionStatusText, FallbackValue=Offline}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Button Content="E-STOP" Command="{Binding EmergencyStopCommand}" FontWeight="Bold" Style="{StaticResource DangerButtonStyle}" />
                        <Button Content="CLR ESTOP" Command="{Binding ClearEmergencyStopCommand}" FontWeight="Bold" Style="{StaticResource SuccessButtonStyle}" />
                        <Button Content="Reconnect" Command="{Binding ReconnectCommand}" FontWeight="Bold" Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl" Grid.Row="2" Background="Transparent" BorderThickness="0" SelectedIndex="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Dashboard">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="6">
                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="System State" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.SystemState}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="EtherCAT Status" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.EtherCatNetworkState}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Connected" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.EtherCatConnected}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Online Slaves" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.EtherCatOnlineSlaveCount}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Alarm Count" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.AlarmCount}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Active IO" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding Dashboard.ActiveInputCount}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                                    <TextBlock Text="DI ON" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Dashboard.ActiveOutputCount}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                    <TextBlock Text="DO ON" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Alarm Log" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Recent system alarms and key notifications" Style="{StaticResource SectionHintTextStyle}" />
                                    <ListBox ItemsSource="{Binding Dashboard.AlarmLog}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="System Overview" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Use the left navigation to jump into detailed control pages." Style="{StaticResource SectionHintTextStyle}" />
                                    <ItemsControl>
                                        <ItemsControl.Items>
                                            <TextBlock Text="• Axis Console for jog, move and parameter management" Margin="0,0,0,8" />
                                            <TextBlock Text="• IO Monitor for DI/DO status and configuration" Margin="0,0,0,8" />
                                            <TextBlock Text="• Work Head and Position Setup for process objects" Margin="0,0,0,8" />
                                            <TextBlock Text="• Alarm Center for active fault review" />
                                        </ItemsControl.Items>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="EtherCAT Monitor">
                    <Grid Margin="0">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="EtherCAT Monitor" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="Realtime slave status, topology path and fault visibility" Style="{StaticResource SectionHintTextStyle}" />
                                <DataGrid ItemsSource="{Binding EtherCatMonitor.Slaves}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Slave No" Binding="{Binding SlaveNo}" Width="90" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                                        <DataGridTextColumn Header="Module Type" Binding="{Binding ModuleType}" Width="130" />
                                        <DataGridTextColumn Header="Module State" Binding="{Binding ModuleState}" Width="130" />
                                        <DataGridTextColumn Header="Topology" Binding="{Binding TopologyPath}" Width="130" />
                                        <DataGridTextColumn Header="Vendor ID" Binding="{Binding VendorId}" Width="120" />
                                        <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="140" />
                                        <DataGridTextColumn Header="Fault Text" Binding="{Binding FaultText}" Width="220" />
                                        <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline, Mode=OneWay}" Width="90" />
                                        <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm, Mode=OneWay}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Axis Console">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Axis Console" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Axis control, jog operation and controller parameters" Style="{StaticResource SectionHintTextStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="Page Commands" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right" Margin="0,0,0,8" />
                                    <WrapPanel HorizontalAlignment="Right">
                                        <Button Content="Add Axis" Command="{Binding AddAxisCommand}" MinWidth="104" />
                                        <Button Content="Delete Axis" Command="{Binding DeleteAxisCommand}" MinWidth="104" Style="{StaticResource DangerButtonStyle}" />
                                        <Button Content="Save" Command="{Binding SaveAxisConsoleConfigCommand}" Width="124" Style="{StaticResource SuccessButtonStyle}" />
                                        <Button Content="Load" Command="{Binding LoadAxisConsoleConfigCommand}" Width="124" Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Content="Read Ctrl" Command="{Binding AxisParameterEditor.ReadControllerCommand}" Width="124" Style="{StaticResource SecondaryButtonStyle}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.1*" MinWidth="420" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1.45*" MinWidth="320" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="420" />
                            </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Axis Monitor" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Text="Real-time axis overview and selection" Style="{StaticResource SectionHintTextStyle}" Margin="0,0,0,0" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="Monitoring Panel" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Top" />
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          x:Name="AxisMonitorDataGrid"
                                          ItemsSource="{Binding AxisMonitor.Axes}"
                                          SelectedItem="{Binding AxisMonitor.SelectedAxis, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HorizontalScrollBarVisibility="Auto"
                                          PreviewMouseWheel="AxisMonitorDataGrid_PreviewMouseWheel">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Axis No" Binding="{Binding AxisNo}" Width="72" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" />
                                        <DataGridTextColumn Header="Cmd (mm)" Binding="{Binding CommandPositionMm, StringFormat=F3}" Width="96" />
                                        <DataGridTextColumn Header="Enc (mm)" Binding="{Binding EncoderPositionMm, StringFormat=F3}" Width="96" />
                                        <DataGridTextColumn Header="Work Vel" Binding="{Binding WorkVelocity}" Width="82" />
                                        <DataGridTextColumn Header="Setup Vel" Binding="{Binding SetupVelocity}" Width="82" />
                                        <DataGridCheckBoxColumn Header="Homed" Binding="{Binding IsHomed, Mode=OneWay}" Width="58">
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                        </DataGridCheckBoxColumn>
                                        <DataGridTemplateColumn Header="Servo" Width="78">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsServoOn, Mode=OneWay}" Command="{Binding ToggleServoCommand}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Alarm" Width="64">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding HasAlarm, Mode=OneWay}" Command="{Binding ClearAlarmCommand}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridCheckBoxColumn Header="Soft-" Binding="{Binding NegativeSoftLimitTriggered, Mode=OneWay}" Width="60">
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                        </DataGridCheckBoxColumn>
                                        <DataGridCheckBoxColumn Header="Soft+" Binding="{Binding PositiveSoftLimitTriggered, Mode=OneWay}" Width="60">
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                        </DataGridCheckBoxColumn>
                                        <DataGridCheckBoxColumn Header="Hard-" Binding="{Binding NegativeHardLimitTriggered, Mode=OneWay}" Width="60">
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                        </DataGridCheckBoxColumn>
                                        <DataGridCheckBoxColumn Header="Hard+" Binding="{Binding PositiveHardLimitTriggered, Mode=OneWay}" Width="60">
                                            <DataGridCheckBoxColumn.ElementStyle>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridCheckBoxColumn.ElementStyle>
                                        </DataGridCheckBoxColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 1: Title + Selected Axis badge -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Axis Manual Operation" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Text="Single-axis move, jog and runtime feedback" Style="{StaticResource SectionHintTextStyle}" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#223240" BorderBrush="#445A6C" BorderThickness="1" CornerRadius="10" Padding="14,6" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Axis " Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding AxisDebug.SelectedAxisNo}" FontSize="22" FontWeight="Bold" Foreground="#E8F4FD" VerticalAlignment="Center" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Row 2: Parameter form 2x2 -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Target Position" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                        <TextBox Text="{Binding AxisDebug.TargetPosition, StringFormat=F3}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Velocity" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                        <TextBox Text="{Binding AxisDebug.Velocity}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Acceleration" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                        <TextBox Text="{Binding AxisDebug.Acceleration}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Deceleration" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                                        <TextBox Text="{Binding AxisDebug.Deceleration}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Row 3: Home / Move / Stop -->
                                <UniformGrid Grid.Row="4" Columns="3" Margin="0">
