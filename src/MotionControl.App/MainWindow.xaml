<Window x:Class="MotionControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        StartupLocation="CenterScreen"
        Title="Motion Control" Height="720" Width="1200">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="Dashboard">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="System Overview" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="LightSteelBlue" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="系统状态" FontWeight="Bold" />
                                <TextBlock Text="{Binding Dashboard.SystemState}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="LightCyan" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="EtherCAT 网络状态" FontWeight="Bold" />
                                <TextBlock Text="{Binding Dashboard.EtherCatNetworkState}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="Honeydew" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="EtherCAT 已连接" FontWeight="Bold" />
                                <TextBlock Text="{Binding Dashboard.EtherCatConnected}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="Lavender" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="在线从站数" FontWeight="Bold" />
                                <TextBlock Text="{Binding Dashboard.EtherCatOnlineSlaveCount}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="MistyRose" CornerRadius="6" Padding="8">
                            <StackPanel>
                                <TextBlock Text="报警数量" FontWeight="Bold" />
                                <TextBlock Text="{Binding Dashboard.AlarmCount}" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="180" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0" ItemsSource="{Binding Dashboard.EtherCatSlaves}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SlaveNo" Binding="{Binding SlaveNo}" Width="100" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                                <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline}" Width="100" />
                                <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GroupBox Grid.Row="1" Header="Recent Command Feedback">
                            <ListBox ItemsSource="{Binding Dashboard.RecentCommandFeedback}" />
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Axis Monitor">
                <DataGrid ItemsSource="{Binding AxisMonitor.Axes}" AutoGenerateColumns="False" IsReadOnly="True" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="AxisNo" Binding="{Binding AxisNo}" Width="80" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" />
                        <DataGridTextColumn Header="Position" Binding="{Binding CurrentPosition}" Width="120" />
                        <DataGridTextColumn Header="Velocity" Binding="{Binding CurrentVelocity}" Width="120" />
                        <DataGridTextColumn Header="HomeMode" Binding="{Binding HomeMode}" Width="140" />
                        <DataGridTextColumn Header="ServoBinding" Binding="{Binding ServoBinding}" Width="140" />
                        <DataGridTextColumn Header="SoftLimit" Binding="{Binding SoftLimitDisplay}" Width="180" />
                        <DataGridCheckBoxColumn Header="Homed" Binding="{Binding IsHomed}" Width="80" />
                        <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Axis Debug">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Width="320">
                        <TextBlock Text="Axis Debug" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                        <TextBlock Text="Axis No" />
                        <TextBox Text="{Binding AxisDebug.SelectedAxisNo}" Margin="0,0,0,8" />
                        <TextBlock Text="Target Position" />
                        <TextBox Text="{Binding AxisDebug.TargetPosition}" Margin="0,0,0,8" />
                        <TextBlock Text="Velocity" />
                        <TextBox Text="{Binding AxisDebug.Velocity}" Margin="0,0,0,8" />
                        <TextBlock Text="Acceleration" />
                        <TextBox Text="{Binding AxisDebug.Acceleration}" Margin="0,0,0,8" />
                        <TextBlock Text="Deceleration" />
                        <TextBox Text="{Binding AxisDebug.Deceleration}" Margin="0,0,0,12" />
                        <WrapPanel>
                            <Button Content="Enable" Command="{Binding AxisDebug.EnableAxisCommand}" Margin="0,0,8,8" Width="90" />
                            <Button Content="Home" Command="{Binding AxisDebug.HomeAxisCommand}" Margin="0,0,8,8" Width="90" />
                            <Button Content="Move" Command="{Binding AxisDebug.MoveAxisCommand}" Margin="0,0,8,8" Width="90" />
                            <Button Content="Stop" Command="{Binding AxisDebug.StopAxisCommand}" Margin="0,0,8,8" Width="90" />
                            <Button Content="Jog +" Command="{Binding AxisDebug.JogPositiveCommand}" Margin="0,0,8,8" Width="90" />
                            <Button Content="Jog -" Command="{Binding AxisDebug.JogNegativeCommand}" Margin="0,0,8,8" Width="90" />
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Selected Axis Metadata" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="HomeMode" FontWeight="Bold" />
                            <TextBlock Text="{Binding AxisDebug.SelectedAxisHomeMode}" Margin="0,0,0,8" />
                            <TextBlock Text="ServoBinding" FontWeight="Bold" />
                            <TextBlock Text="{Binding AxisDebug.SelectedAxisServoBinding}" Margin="0,0,0,8" />
                            <TextBlock Text="SoftLimit" FontWeight="Bold" />
                            <TextBlock Text="{Binding AxisDebug.SelectedAxisSoftLimit}" Margin="0,0,0,12" />
                            <TextBlock Text="Home Plan" FontSize="18" FontWeight="Bold" Margin="0,8,0,12" />
                            <TextBlock Text="{Binding AxisDebug.SelectedHomePlanTitle}" FontWeight="Bold" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding AxisDebug.SelectedHomePlanSteps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Margin="0,0,0,6" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="EtherCAT Monitor">
                <Grid Margin="12">
                    <DataGrid ItemsSource="{Binding EtherCatMonitor.Dashboard.EtherCatSlaves}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SlaveNo" Binding="{Binding SlaveNo}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                            <DataGridTextColumn Header="ModuleType" Binding="{Binding ModuleType}" Width="140" />
                            <DataGridTextColumn Header="FaultText" Binding="{Binding FaultText}" Width="220" />
                            <DataGridCheckBoxColumn Header="Online" Binding="{Binding IsOnline}" Width="100" />
                            <DataGridCheckBoxColumn Header="Alarm" Binding="{Binding HasAlarm}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Alarm">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Alarm Center" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

                    <GroupBox Grid.Row="1" Header="Active Alarm Axes" Margin="0,8,0,12">
                        <ListBox ItemsSource="{Binding Alarm.ActiveAlarmAxes}" />
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Alarm.ActiveAlarms}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="220" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" />
                            <DataGridTextColumn Header="OccurredAt" Binding="{Binding OccurredAt}" Width="180" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
