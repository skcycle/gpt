<Window x:Class="MotionControl.App.Views.Dialogs.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        Width="420"
        SizeToContent="Height"
        MaxWidth="560"
        MinWidth="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0C141C"
        Foreground="#E7EEF5"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Effect>
        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
    </Window.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#18242F" CornerRadius="12,12,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Icon -->
                <Border Grid.Column="0" x:Name="IconContainer" Width="36" Height="36" CornerRadius="8" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock x:Name="IconText" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E7EEF5"/>
                </Border>
                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#E7EEF5"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Message -->
        <Border Grid.Row="1" Background="#1D2B36" Padding="20,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="MessageText"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
                           Foreground="#AAB8C5"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#18242F" CornerRadius="0,0,12,12" Padding="16,14">
            <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
