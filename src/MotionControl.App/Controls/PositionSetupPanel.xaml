<UserControl x:Class="MotionControl.App.Controls.PositionSetupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────── -->
        <controls:PageHeader Grid.Row="0">
            <controls:PageHeader.Commands>
                <WrapPanel>
                    <Button Content="Add Object"      Command="{Binding AddPositionSetupCommand}"              Margin="0,0,8,0" MinWidth="100" />
                    <Button Content="Delete Object"   Command="{Binding DeletePositionSetupCommand}"          Margin="0,0,8,0" MinWidth="112" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Add Position"    Command="{Binding AddPositionSetupPositionCommand}"   Margin="0,0,8,0" MinWidth="108" />
                    <Button Content="Delete Position" Command="{Binding DeletePositionSetupPositionCommand}" Margin="0,0,8,0" MinWidth="120" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Save"           Command="{Binding SavePositionSetupConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SuccessButtonStyle}" />
                    <Button Content="Load"           Command="{Binding LoadPositionSetupConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </controls:PageHeader.Commands>
        </controls:PageHeader>

        <!-- ── Three-Column Editor ─────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Object list -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Objects" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Reusable position setup objects" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                             ItemsSource="{Binding PositionSetupMonitor.Items}"
                             SelectedItem="{Binding PositionSetupMonitor.SelectedItem, Mode=TwoWay}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             IsReadOnly="False"
                             PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Position list -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Positions" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Named position entries under the current object" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding PositionSetupMonitor.SelectedItem.Positions}"
                              SelectedItem="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Detail editor -->
            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Axis Mapping (7 axes → 4 + 3 rows) -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Axis Mapping" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="4">
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Xx Axis" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XxAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="X Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Y Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Z Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                </UniformGrid>
                                <UniformGrid Columns="3">
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="U Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.UAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="V Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.VAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="W Axis"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.WAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Position Values (7 axes → 4 + 3 rows) -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Position Values" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="4">
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Xx Pos" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XxPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXxAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="X Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Y Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.YPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsYAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Z Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.ZPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsZAxisConfigured}" /></StackPanel>
                                </UniformGrid>
                                <UniformGrid Columns="3">
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="U Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.UPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsUAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="V Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.VPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsVAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="W Pos"  Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.WPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsWAxisConfigured}" /></StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Safe Z + Description -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Safe Z"        Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0" />
                                <TextBox   Grid.Column="1" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="3" Text="Description" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0" />
                                <TextBox   Grid.Column="4" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <!-- Position commands -->
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Teach" Command="{Binding TeachPositionSetupCommand}" Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Move"  Command="{Binding MovePositionSetupCommand}" Margin="0,0,8,0" MinWidth="90" />
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Event Log ───────────────────────────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Position Setup Event Log" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Grid.Row="1" Text="Teach, move and configuration activity history" Style="{StaticResource SectionHintTextStyle}" />
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding PositionSetupEventLog.Events}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Style="{StaticResource EventLogDataGridStyle}"
                          PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"     Binding="{Binding Time}"          Width="110" />
                        <DataGridTextColumn Header="Position" Binding="{Binding PositionName}"  Width="180" />
                        <DataGridTextColumn Header="Event"    Binding="{Binding EventType}"     Width="120" />
                        <DataGridTextColumn Header="Message"  Binding="{Binding Message}"      Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>
