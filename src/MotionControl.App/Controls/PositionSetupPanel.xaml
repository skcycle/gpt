<UserControl x:Class="MotionControl.App.Controls.PositionSetupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
<Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Position Setup" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Reusable position objects, axis mapping and target values" Style="{StaticResource SectionHintTextStyle}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Content="Add Object" Command="{Binding AddPositionSetupCommand}" Margin="0,0,8,0" MinWidth="100" />
                                    <Button Content="Delete Object" Command="{Binding DeletePositionSetupCommand}" Margin="0,0,8,0" MinWidth="112" Style="{StaticResource DangerButtonStyle}" />
                                    <Button Content="Add Position" Command="{Binding AddPositionSetupPositionCommand}" Margin="0,0,8,0" MinWidth="108" />
                                    <Button Content="Delete Position" Command="{Binding DeletePositionSetupPositionCommand}" Margin="0,0,8,0" MinWidth="120" Style="{StaticResource DangerButtonStyle}" />
                                    <Button Content="Save" Command="{Binding SavePositionSetupConfigCommand}" Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SuccessButtonStyle}" />
                                    <Button Content="Load" Command="{Binding LoadPositionSetupConfigCommand}" Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" MinWidth="160" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="220" MinWidth="160" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Objects" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Grid.Row="1" Text="Reusable position setup objects" Style="{StaticResource SectionHintTextStyle}" />
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding PositionSetupMonitor.Items}"
                                              SelectedItem="{Binding PositionSetupMonitor.SelectedItem, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Positions" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Grid.Row="1" Text="Named position entries under the current object" Style="{StaticResource SectionHintTextStyle}" />
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding PositionSetupMonitor.SelectedItem.Positions}"
                                              SelectedItem="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <Grid Margin="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Axis Mapping" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="7">
                                                    <StackPanel Margin="4"><TextBlock Text="Xx Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XxAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="X Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Y Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Z Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="U Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.UAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="V Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.VAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="W Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.WAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Position Values" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="7">
                                                    <StackPanel Margin="4"><TextBlock Text="Xx Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XxPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXxAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="X Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.XPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsXAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Y Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.YPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsYAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Z Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.ZPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsZAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="U Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.UPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsUAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="V Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.VPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsVAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="W Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding PositionSetupMonitor.SelectedItem.SelectedPosition.WPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding PositionSetupMonitor.SelectedItem.IsWAxisConfigured}" /></StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
                                            <Grid Margin="4,0,4,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Safe Z" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="3" Text="Description" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="4" Margin="10,0,0,0" Text="{Binding PositionSetupMonitor.SelectedItem.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </Border>

                                        <WrapPanel Grid.Row="6" Orientation="Horizontal" Margin="4,4,4,4">
                                            <Button Content="Teach" Command="{Binding TeachPositionSetupCommand}" Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Content="Move" Command="{Binding MovePositionSetupCommand}" Margin="0,0,8,0" MinWidth="90" />
                                        </WrapPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Position Setup Event Log" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Grid.Row="1" Text="Teach, move and configuration activity history" Style="{StaticResource SectionHintTextStyle}" />
                                <DataGrid Grid.Row="2" ItemsSource="{Binding PositionSetupEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True" PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                        <DataGridTextColumn Header="Position" Binding="{Binding PositionName}" Width="180" />
                                        <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="120" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
</UserControl>
