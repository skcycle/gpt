<UserControl x:Class="MotionControl.App.Controls.EtherCatMonitorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────── -->
        <controls:PageHeader Title="EtherCAT Monitor"
                             Hint="EtherCAT bus topology, device listing and runtime state monitoring"
                             Grid.Row="0" />

        <!-- ── Slave Status Grid ──────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
            <DataGrid ItemsSource="{Binding EtherCatMonitor.Slaves}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      controls:ScrollHelper.EnableScrollOnDataGrid="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Slave No"     Binding="{Binding SlaveNo}"       Width="90"  />
                    <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="180" />
                    <DataGridTextColumn Header="State"         Binding="{Binding State}"        Width="120" />
                    <DataGridTextColumn Header="Module Type"   Binding="{Binding ModuleType}"    Width="130" />
                    <DataGridTextColumn Header="Module State"  Binding="{Binding ModuleState}"   Width="130" />
                    <DataGridTextColumn Header="Topology"      Binding="{Binding TopologyPath}"  Width="130" />
                    <DataGridTextColumn Header="Vendor ID"    Binding="{Binding VendorId}"      Width="120" />
                    <DataGridTextColumn Header="Product Code"  Binding="{Binding ProductCode}"   Width="140" />
                    <DataGridTextColumn Header="Fault Text"    Binding="{Binding FaultText}"     Width="220" />
                    <DataGridCheckBoxColumn Header="Online"   Binding="{Binding IsOnline, Mode=OneWay}" Width="90" />
                    <DataGridCheckBoxColumn Header="Alarm"    Binding="{Binding HasAlarm, Mode=OneWay}"  Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>
