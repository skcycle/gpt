<UserControl x:Class="MotionControl.App.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="800">
    <Border Style="{StaticResource SectionCardStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=controls:PageHeader}}"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="{Binding Hint, RelativeSource={RelativeSource AncestorType=controls:PageHeader}}"
                           Style="{StaticResource SectionHintTextStyle}" />
            </StackPanel>

            <!-- Commands: inherits DataContext from parent UserControl automatically -->
            <ContentPresenter Grid.Column="1"
                              Content="{Binding Commands, RelativeSource={RelativeSource AncestorType=controls:PageHeader}}"
                              VerticalAlignment="Top" />
        </Grid>
    </Border>
</UserControl>
