<UserControl x:Class="MotionControl.App.Controls.WorkHeadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
<Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Work Head" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Work head objects, positions and vacuum IO setup" Style="{StaticResource SectionHintTextStyle}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Content="Add Object" Command="{Binding AddWorkHeadCommand}" MinWidth="100" />
                                    <Button Content="Delete Object" Command="{Binding DeleteWorkHeadCommand}" MinWidth="112" Style="{StaticResource DangerButtonStyle}" />
                                    <Button Content="Add Position" Command="{Binding AddWorkHeadPositionCommand}" MinWidth="108" />
                                    <Button Content="Delete Position" Command="{Binding DeleteWorkHeadPositionCommand}" MinWidth="120" Style="{StaticResource DangerButtonStyle}" />
                                    <Button Content="Save" Command="{Binding SaveWorkHeadConfigCommand}" MinWidth="90" Style="{StaticResource SuccessButtonStyle}" />
                                    <Button Content="Load" Command="{Binding LoadWorkHeadConfigCommand}" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" MinWidth="160" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="220" MinWidth="160" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Objects" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Grid.Row="1" Text="Available work head objects" Style="{StaticResource SectionHintTextStyle}" />
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding WorkHeadMonitor.WorkHeads}"
                                              SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Positions" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Grid.Row="1" Text="Named points under the selected work head" Style="{StaticResource SectionHintTextStyle}" />
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding WorkHeadMonitor.SelectedWorkHead.Positions}"
                                              SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead.SelectedPosition, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <Grid Margin="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Axis Mapping" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="4">
                                                    <StackPanel Margin="4"><TextBlock Text="X Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Y Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Z Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="R Axis" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.RAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Target Position" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="4">
                                                    <StackPanel Margin="4"><TextBlock Text="X Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsXAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Y Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsYAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Z Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsZAxisConfigured}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="R Pos" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsRAxisConfigured}" /></StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
                                            <Grid Margin="4,0,4,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Safe Z" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="3" Text="Description" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="4" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </Border>

                                        <Border Grid.Row="6" Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Vacuum and IO" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="8">
                                                    <StackPanel Margin="4"><TextBlock Text="Vacuum DO" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Blow DO" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.BlowOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Vacuum DI" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="General DO 1" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="General DO 2" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="General DI 1" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="General DI 2" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    <StackPanel Margin="4"><TextBlock Text="Vacuum Timeout(ms)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <WrapPanel Grid.Row="8" Orientation="Horizontal" Margin="4,4,4,4">
                                            <Button Content="Teach" Command="{Binding WorkHeadMonitor.SelectedWorkHead.TeachPositionCommand, FallbackValue={x:Null}}" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button Content="Move" Command="{Binding WorkHeadMonitor.SelectedWorkHead.MovePositionCommand, FallbackValue={x:Null}}" MinWidth="90" />
                                            <Button Content="Vacuum" Command="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumCommand, FallbackValue={x:Null}}" MinWidth="96" Style="{StaticResource SuccessButtonStyle}" />
                                            <Button Content="Blow" Command="{Binding WorkHeadMonitor.SelectedWorkHead.BlowCommand, FallbackValue={x:Null}}" MinWidth="90" Style="{StaticResource WarningButtonStyle}" />
                                        </WrapPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                        </Grid>

                        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Work Head Event Log" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Grid.Row="1" Text="Runtime actions, vacuum events and motion feedback" Style="{StaticResource SectionHintTextStyle}" />
                                <DataGrid Grid.Row="2" ItemsSource="{Binding WorkHeadEventLog.Events}" AutoGenerateColumns="False" IsReadOnly="True" PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                                        <DataGridTextColumn Header="WorkHead" Binding="{Binding WorkHeadName}" Width="180" />
                                        <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="120" />
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
</UserControl>
