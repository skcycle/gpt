<UserControl x:Class="MotionControl.App.Controls.WorkHeadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────── -->
        <controls:PageHeader Grid.Row="0">
            <controls:PageHeader.Commands>
                <WrapPanel>
                    <Button Content="Add Object"     Command="{Binding AddWorkHeadCommand}"              Margin="0,0,8,0" MinWidth="100" />
                    <Button Content="Delete Object"  Command="{Binding DeleteWorkHeadCommand}"          Margin="0,0,8,0" MinWidth="112" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Add Position"   Command="{Binding AddWorkHeadPositionCommand}"    Margin="0,0,8,0" MinWidth="108" />
                    <Button Content="Delete Position" Command="{Binding DeleteWorkHeadPositionCommand}" Margin="0,0,8,0" MinWidth="120" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Save"           Command="{Binding SaveWorkHeadConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SuccessButtonStyle}" />
                    <Button Content="Load"           Command="{Binding LoadWorkHeadConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </controls:PageHeader.Commands>
        </controls:PageHeader>

        <!-- ── Three-Column Editor ─────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Object list -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Objects" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Available work head objects" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                             ItemsSource="{Binding WorkHeadMonitor.WorkHeads}"
                             SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead, Mode=TwoWay}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             IsReadOnly="False"
                             Style="{StaticResource EventLogDataGridStyle}"
                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Position list -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Positions" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Named points under the selected work head" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding WorkHeadMonitor.SelectedWorkHead.Positions}"
                              SelectedItem="{Binding WorkHeadMonitor.SelectedWorkHead.SelectedPosition, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Detail editor — outer card, inner sub-sections use SubSectionCardStyle -->
            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Axis Mapping -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Axis Mapping" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="4">
                                    <controls:LabeledTextBox Label="X Axis" Text="{Binding WorkHeadMonitor.SelectedWorkHead.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Y Axis" Text="{Binding WorkHeadMonitor.SelectedWorkHead.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Z Axis" Text="{Binding WorkHeadMonitor.SelectedWorkHead.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="R Axis" Text="{Binding WorkHeadMonitor.SelectedWorkHead.RAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Target Position -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Target Position" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="4">
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="X Pos" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsXAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Y Pos" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsYAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="Z Pos" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsZAxisConfigured}" /></StackPanel>
                                    <StackPanel Style="{StaticResource FieldContainerStyle}"><TextBlock Text="R Pos" Style="{StaticResource FieldLabelStyle}" /><TextBox Text="{Binding WorkHeadMonitor.SelectedWorkHead.PositionR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DisabledAxisPositionTextBoxStyle}" IsEnabled="{Binding WorkHeadMonitor.SelectedWorkHead.IsRAxisConfigured}" /></StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Safe Z + Description -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Safe Z"        Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0" />
                                <TextBox   Grid.Column="1" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.SafeZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Column="3" Text="Description" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0" />
                                <TextBox   Grid.Column="4" Margin="10,0,0,0" Text="{Binding WorkHeadMonitor.SelectedWorkHead.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <!-- Vacuum and IO -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Vacuum and IO" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="4">
                                    <controls:LabeledTextBox Label="Vacuum DO"       Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Blow DO"         Text="{Binding WorkHeadMonitor.SelectedWorkHead.BlowOutputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Vacuum DI"       Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="General DO 1"    Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                                <UniformGrid Columns="4">
                                    <controls:LabeledTextBox Label="General DO 2"    Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralOutputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="General DI 1"    Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="General DI 2"    Text="{Binding WorkHeadMonitor.SelectedWorkHead.GeneralInputAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Vacuum Timeout(ms)" Text="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Position commands -->
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Teach"   Command="{Binding WorkHeadMonitor.SelectedWorkHead.TeachPositionCommand, FallbackValue={x:Null}}"   Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Move"    Command="{Binding WorkHeadMonitor.SelectedWorkHead.MovePositionCommand, FallbackValue={x:Null}}"    Margin="0,0,8,0" MinWidth="90" />
                            <Button Content="Vacuum" Command="{Binding WorkHeadMonitor.SelectedWorkHead.VacuumCommand, FallbackValue={x:Null}}"        Margin="0,0,8,0" MinWidth="96" Style="{StaticResource SuccessButtonStyle}" />
                            <Button Content="Blow"    Command="{Binding WorkHeadMonitor.SelectedWorkHead.BlowCommand, FallbackValue={x:Null}}"         Margin="0,0,8,0" MinWidth="90" Style="{StaticResource WarningButtonStyle}" />
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Event Log ───────────────────────────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Work Head Event Log" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Grid.Row="1" Text="Runtime actions, vacuum events and motion feedback" Style="{StaticResource SectionHintTextStyle}" />
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding WorkHeadEventLog.Events}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"    Binding="{Binding Time}"         Width="110" />
                        <DataGridTextColumn Header="Object" Binding="{Binding ObjectName}"   Width="120" />
                        <DataGridTextColumn Header="Event"  Binding="{Binding EventName}"    Width="120" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}"     Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>
