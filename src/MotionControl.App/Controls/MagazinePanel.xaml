<UserControl x:Class="MotionControl.App.Controls.MagazinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────── -->
        <controls:PageHeader Grid.Row="0">
            <controls:PageHeader.Commands>
                <WrapPanel>
                    <Button Content="Add Object"      Command="{Binding AddMagazineCommand}"              Margin="0,0,8,0" MinWidth="100" />
                    <Button Content="Delete Object"   Command="{Binding DeleteMagazineCommand}"          Margin="0,0,8,0" MinWidth="112" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Add Position"    Command="{Binding AddMagazinePositionCommand}"    Margin="0,0,8,0" MinWidth="108" />
                    <Button Content="Delete Position" Command="{Binding DeleteMagazinePositionCommand}" Margin="0,0,8,0" MinWidth="120" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Save"           Command="{Binding SaveMagazineConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SuccessButtonStyle}" />
                    <Button Content="Load"           Command="{Binding LoadMagazineConfigCommand}"     Margin="0,0,8,0" MinWidth="90"  Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </controls:PageHeader.Commands>
        </controls:PageHeader>

        <!-- ── Three-Column Editor ─────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Object list -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Objects" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Available magazine objects" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                             ItemsSource="{Binding MagazineMonitor.Magazines}"
                             SelectedItem="{Binding MagazineMonitor.SelectedMagazine, Mode=TwoWay}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             IsReadOnly="False"
                             PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Position list -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Positions" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1" Text="Selected magazine named points" Style="{StaticResource SectionHintTextStyle}" />
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding MagazineMonitor.SelectedMagazine.Positions}"
                              SelectedItem="{Binding MagazineMonitor.SelectedMagazine.SelectedPosition, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Detail editor -->
            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Axis Mapping + Layer Status side by side -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Style="{StaticResource SubSectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Axis Mapping" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <UniformGrid Columns="3">
                                            <controls:LabeledTextBox Label="X Axis" Text="{Binding MagazineMonitor.SelectedMagazine.XAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <controls:LabeledTextBox Label="Y Axis" Text="{Binding MagazineMonitor.SelectedMagazine.YAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <controls:LabeledTextBox Label="Z Axis" Text="{Binding MagazineMonitor.SelectedMagazine.ZAxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SubSectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Position Detail" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <UniformGrid Columns="3">
                                            <controls:LabeledTextBox Label="X Pos" Text="{Binding MagazineMonitor.SelectedMagazine.SelectedPosition.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <controls:LabeledTextBox Label="Y Pos" Text="{Binding MagazineMonitor.SelectedMagazine.SelectedPosition.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <controls:LabeledTextBox Label="Z Pos" Text="{Binding MagazineMonitor.SelectedMagazine.SelectedPosition.Z, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Layer Status — compact strip on right -->
                            <Border Grid.Column="2" Style="{StaticResource SubSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Layer Status" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding MagazineMonitor.SelectedMagazine.LayerStatuses}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Vertical" /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="4,4,4,0" Width="80" Height="12" CornerRadius="5" Background="{Binding StatusBrush}" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Layer Parameters -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Layer Parameters" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="5">
                                    <controls:LabeledTextBox Label="Description"       Text="{Binding MagazineMonitor.SelectedMagazine.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Layer Count"      Text="{Binding MagazineMonitor.SelectedMagazine.LayerCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Layer Height"     Text="{Binding MagazineMonitor.SelectedMagazine.LayerHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Pick Lift Height" Text="{Binding MagazineMonitor.SelectedMagazine.PickLiftHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="Scan Settling(ms)" Text="{Binding MagazineMonitor.SelectedMagazine.ScanSettlingMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- IO Inputs -->
                        <Border Style="{StaticResource SubSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="IO Inputs" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <UniformGrid Columns="3">
                                    <controls:LabeledTextBox Label="料仓有无 IN"     Text="{Binding MagazineMonitor.SelectedMagazine.MaterialPresentInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="当前层有料 IN"   Text="{Binding MagazineMonitor.SelectedMagazine.CurrentLayerHasMaterialInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <controls:LabeledTextBox Label="料盘防呆 IN"    Text="{Binding MagazineMonitor.SelectedMagazine.TrayKeyingInputAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Position commands -->
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Teach" Command="{Binding TeachMagazinePositionCommand}"  Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Move"  Command="{Binding MoveMagazinePositionCommand}" Margin="0,0,8,0" MinWidth="90" />
                            <Button Content="Scan"  Command="{Binding ScanMagazineCommand}"          Margin="0,0,8,0" MinWidth="90" Style="{StaticResource SuccessButtonStyle}" />
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Event Log ───────────────────────────────────────────── -->
        <controls:EventLogPanel Grid.Row="4"
                                Title="Magazine Event Log"
                                Hint="Runtime actions, vacuum events and IO feedback">
            <DataGrid ItemsSource="{Binding MagazineEventLog.Events}"
                      Style="{StaticResource SectionDataGridStyle}"
                      PreviewMouseWheel="SectionDataGrid_PreviewMouseWheel">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"     Binding="{Binding Timestamp}"     Width="110" />
                    <DataGridTextColumn Header="Magazine" Binding="{Binding MagazineName}"  Width="180" />
                    <DataGridTextColumn Header="Event"    Binding="{Binding EventType}"    Width="120" />
                    <DataGridTextColumn Header="Message"  Binding="{Binding Message}"      Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </controls:EventLogPanel>

    </Grid>
</UserControl>
