<UserControl x:Class="MotionControl.App.Controls.AxisConsolePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header ═══ -->
        <controls:PageHeader Grid.Row="0">
            <controls:PageHeader.Commands>
                <WrapPanel>
                    <Button Content="Add Axis"    Command="{Binding AddAxisCommand}"    MinWidth="104" />
                    <Button Content="Delete Axis" Command="{Binding DeleteAxisCommand}" MinWidth="104" Style="{StaticResource DangerButtonStyle}" />
                    <Button Content="Save"       Command="{Binding SaveAxisConsoleConfigCommand}" MinWidth="124" Style="{StaticResource SuccessButtonStyle}" />
                    <Button Content="Load"       Command="{Binding LoadAxisConsoleConfigCommand}" MinWidth="124" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="Read Ctrl"  Command="{Binding AxisParameterEditor.ReadControllerCommand}" MinWidth="124" Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </controls:PageHeader.Commands>
        </controls:PageHeader>

        <!-- ═══ Row 2: 3-panel columns ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="420" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="2*" MinWidth="320" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- ── Column 0: Axis Monitor ── -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Axis Monitor" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Real-time axis overview and selection" Style="{StaticResource SectionHintTextStyle}" Margin="0,0,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Monitoring Panel" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Top" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              x:Name="AxisMonitorDataGrid"
                              ItemsSource="{Binding AxisMonitor.Axes}"
                              SelectedItem="{Binding AxisMonitor.SelectedAxis, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HorizontalScrollBarVisibility="Auto"
                              PreviewMouseWheel="AxisMonitorDataGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Axis No" Binding="{Binding AxisNo}" Width="72" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120" />
                            <DataGridTextColumn Header="Cmd (mm)" Binding="{Binding CommandPositionMm, StringFormat=F3}" Width="96" />
                            <DataGridTextColumn Header="Enc (mm)" Binding="{Binding EncoderPositionMm, StringFormat=F3}" Width="96" />
                            <DataGridTextColumn Header="Work Vel" Binding="{Binding WorkVelocity}" Width="82" />
                            <DataGridTextColumn Header="Setup Vel" Binding="{Binding SetupVelocity}" Width="82" />
                            <DataGridCheckBoxColumn Header="Homed" Binding="{Binding IsHomed, Mode=OneWay}" Width="58">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridTemplateColumn Header="Servo" Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsServoOn, Mode=OneWay}" Command="{Binding ToggleServoCommand}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Alarm" Width="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding HasAlarm, Mode=OneWay}" Command="{Binding ClearAlarmCommand}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Soft-" Binding="{Binding NegativeSoftLimitTriggered, Mode=OneWay}" Width="60">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Header="Soft+" Binding="{Binding PositiveSoftLimitTriggered, Mode=OneWay}" Width="60">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Header="Hard-" Binding="{Binding NegativeHardLimitTriggered, Mode=OneWay}" Width="60">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Header="Hard+" Binding="{Binding PositiveHardLimitTriggered, Mode=OneWay}" Width="60">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ── Column 2: Axis Manual Operation + Capture ── -->
            <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="280" />
                    </Grid.RowDefinitions>

                    <!-- Title + Selected Axis badge -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Axis Manual Operation" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Single-axis move, jog and runtime feedback" Style="{StaticResource SectionHintTextStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#223240" BorderBrush="#445A6C" BorderThickness="1" CornerRadius="10" Padding="14,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Axis " Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding AxisDebug.SelectedAxisNo}" FontSize="22" FontWeight="Bold" Foreground="#E8F4FD" VerticalAlignment="Center" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Target Position + Velocity + Acc/Dec + Jog Step -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Target Position" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2" />
                            <TextBox Text="{Binding AxisDebug.TargetPosition, StringFormat=F3}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Velocity" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2" />
                            <TextBox Text="{Binding AxisDebug.Velocity}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Acc/Dec" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2" />
                            <TextBox Text="{Binding AxisDebug.Acceleration}" Margin="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                            <TextBlock Text="Jog Step" Foreground="{StaticResource SecondaryTextBrush}" FontSize="11" />
                            <ComboBox ItemsSource="{Binding AxisDebug.JogStepDistances}"
                                      SelectedItem="{Binding AxisDebug.JogStepDistance, Mode=TwoWay}"
                                      FontSize="11"
                                      MinWidth="90"
                                      IsEditable="True"
                                      IsReadOnly="True">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat='{}{0} mm'}" FontSize="11" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Home / Move / Stop / Jog- / Jog+ -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Home" Command="{Binding AxisDebug.HomeAxisCommand}" Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="4,5" />
                        <Button Grid.Column="2" Content="Move" Command="{Binding AxisDebug.MoveAxisCommand}" FontSize="11" Padding="4,5" />
                        <Button Grid.Column="4" Content="Stop" Command="{Binding AxisDebug.StopAxisCommand}" Style="{StaticResource DangerButtonStyle}" FontSize="11" Padding="4,5" />
                        <Button Grid.Column="6" x:Name="JogNegativeButton" Content="Jog -"
                                PreviewMouseLeftButtonDown="JogNegativeButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp"
                                MouseLeave="JogButton_MouseLeave"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="4,5" />
                        <Button Grid.Column="8" x:Name="JogPositiveButton" Content="Jog +"
                                PreviewMouseLeftButtonDown="JogPositiveButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp"
                                MouseLeave="JogButton_MouseLeave"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="11" Padding="4,5" />
                    </Grid>

                    <!-- Curve Capture toolbar -->
                    <Border Grid.Row="4" Background="#16212C" CornerRadius="6" Padding="6,4" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="Spd" IsChecked="{Binding AxisDataCapture.ShowSpeed}" Foreground="#F0C040" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="Speed" />
                                <CheckBox Content="Cmd" IsChecked="{Binding AxisDataCapture.ShowCmdPosition}" Foreground="#4FC3F7" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="Command Position" />
                                <CheckBox Content="Enc" IsChecked="{Binding AxisDataCapture.ShowEncPosition}" Foreground="#81C784" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" ToolTip="Encoder Position" />
                                <TextBlock Text="Dur:" Foreground="{StaticResource SecondaryTextBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox ItemsSource="{Binding AxisDataCapture.CaptureDurations}"
                                          SelectedItem="{Binding AxisDataCapture.CaptureDurationMs}"
                                          FontSize="10" Width="64" VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat='{}{0} ms'}" FontSize="10" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Start" Command="{Binding AxisDataCapture.StartCaptureCommand}"
                                        Style="{StaticResource SuccessButtonStyle}" FontSize="10" Padding="4,5" Margin="0,0,6,0" />
                                <Button Content="Stop" Command="{Binding AxisDataCapture.StopCaptureCommand}"
                                        Style="{StaticResource DangerButtonStyle}" FontSize="10" Padding="4,5" Margin="0,0,6,0" />
                                <Button Content="Clear" Command="{Binding AxisDataCapture.ClearCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" FontSize="10" Padding="4,5" Margin="0,0,6,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Motion Curve Canvas -->
                    <Border Grid.Row="6" Background="#0D1620" CornerRadius="8" Padding="2">
                        <Canvas x:Name="MotionCurveCanvas"
                                ClipToBounds="True"
                                Background="Transparent"
                                SizeChanged="MotionCurveCanvas_SizeChanged">
                            <Polyline x:Name="SpeedCurvePolyline"
                                      Stroke="#F0C040" StrokeThickness="1.2"
                                      Points="{Binding AxisDataCapture.SpeedLinePointsRight}"
                                      Visibility="{Binding AxisDataCapture.ShowSpeed, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Polyline x:Name="CmdCurvePolyline"
                                      Stroke="#4FC3F7" StrokeThickness="1.2"
                                      Points="{Binding AxisDataCapture.CmdLinePoints}"
                                      Visibility="{Binding AxisDataCapture.ShowCmdPosition, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Polyline x:Name="EncCurvePolyline"
                                      Stroke="#81C784" StrokeThickness="1.2"
                                      Points="{Binding AxisDataCapture.EncLinePoints}"
                                      Visibility="{Binding AxisDataCapture.ShowEncPosition, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Canvas>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Column 4: Axis Parameters ── -->
            <Border Grid.Column="4" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="16">
                <ScrollViewer x:Name="AxisParametersScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="AxisParametersScrollViewer_PreviewMouseWheel">
                    <StackPanel>
                        <TextBlock Text="Axis Parameters" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Configuration values for the selected axis" Style="{StaticResource SectionHintTextStyle}" />

                        <TextBlock Text="Axis No" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.AxisNo}" IsReadOnly="True" Width="200" />

                        <TextBlock Text="Name" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.Name}" Width="200" />

                        <TextBlock Text="SoftLimit Negative" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.SoftLimitNegative}" Width="200" />

                        <TextBlock Text="SoftLimit Positive" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.SoftLimitPositive}" Width="200" />

                        <TextBlock Text="Work Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.WorkVelocity}" Width="200" />

                        <TextBlock Text="Setup Velocity" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.SetupVelocity}" Width="200" />

                        <TextBlock Text="Acceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.Acceleration}" Width="200" />

                        <TextBlock Text="Deceleration" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.Deceleration}" Width="200" />

                        <TextBlock Text="Pulse Equivalent (pulse/mm)" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.PulseEquivalent}" Width="200" />

                        <TextBlock Text="HomeMode" Foreground="{StaticResource SecondaryTextBrush}" />
                        <ComboBox ItemsSource="{Binding AxisParameterEditor.HomeModes}" SelectedItem="{Binding AxisParameterEditor.HomeMode}" Width="200" />

                        <TextBlock Text="Servo Binding" Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBox Text="{Binding AxisParameterEditor.ServoBinding}" Margin="0,6,0,12" Width="200" />

                        <TextBlock Text="{Binding AxisParameterEditor.ControllerParameterSnapshot}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <!-- ═══ Row 4: Runtime Event Log ═══ -->
        <controls:EventLogPanel Grid.Row="4"
                                Title="Runtime Event Log"
                                Hint="Axis runtime feedback, move results and jog activity">
            <DataGrid ItemsSource="{Binding Dashboard.RecentAxisCommandFeedback}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="180"
                      Style="{StaticResource SectionDataGridStyle}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"    Binding="{Binding Time}"    Width="110" />
                    <DataGridTextColumn Header="Axis"   Binding="{Binding Axis}"   Width="80" />
                    <DataGridTextColumn Header="Event"  Binding="{Binding Event}" Width="160" />
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </controls:EventLogPanel>
    </Grid>
</UserControl>
