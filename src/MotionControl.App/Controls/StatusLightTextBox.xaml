<UserControl x:Class="MotionControl.App.Controls.StatusLightTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MotionControl.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="24" d:DesignWidth="80">
    <!--
    Status indicator + address TextBox for DI/DO columns.
    Properties:
        StatusBrush : Brush       - fill color for the status Ellipse
        Text        : string       - TwoWay bound address value
    -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Ellipse Width="12" Height="12"
                 Fill="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Stroke="#404040" StrokeThickness="1"
                 Margin="0,0,6,0" />
        <TextBox Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl},
                                Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="52" HorizontalContentAlignment="Center" />
    </StackPanel>
</UserControl>
